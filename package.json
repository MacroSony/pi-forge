{
  "name": "@zihanw/pi-forge",
  "version": "0.2.0",
  "description": "Pi extension for prompt stack and agent profile management.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "prompt-stack"
  ],
  "license": "MIT",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-agent-core": {
      "optional": true
    },
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@types/node": "latest",
    "typescript": "latest",
    "typebox": "latest"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.ts"
  },
  "files": [
    "src/",
    "examples/",
    "README.md",
    "README.zh-CN.md",
    "LICENSE*"
  ],
  "publishConfig": {
    "access": "public"
  }
}
